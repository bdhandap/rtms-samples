FROM node:20-slim
WORKDIR /app
COPY package*.json ./
RUN npm ci --only=production && npm cache clean --force
COPY index.js ./
RUN groupadd -r appuser && useradd -r -g appuser appuser
RUN rm -rf logs && mkdir -p logs
COPY logs/.gitkeep ./logs/
RUN chown -R appuser:appuser /app && chmod -R 755 /app/logs
USER appuser
EXPOSE 5050
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 CMD node -e "console.log('Health check passed')" || exit 1
CMD ["npm", "start"]
